# @sentry/cloudflare@10.65.0 deklarerar en peer-dependency på
# @cloudflare/workers-types@^4.x, men vi kör 5.x (verifierat kompatibelt i
# praktiken — tsc/wrangler dry-run gick igenom felfritt). Utan denna rad
# stoppar Cloudflare Workers Builds' `npm clean-install` hårt på ERESOLVE,
# till skillnad från en lokal `npm install` som bara varnar.
legacy-peer-deps=true
