{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ops-hub",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    // Hostnamnsdel av GitHub org-appen (informativt, inte hemligt)
    "GITHUB_ORG": "blixten85"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ops-hub-db",
      "database_id": "5942ecca-cac7-4658-a8a5-5a60733da6c8"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "routes": [
    { "pattern": "ops-hub.denied.se", "custom_domain": true }
  ],
  // Redan live i produktion (skapade via en tidigare manuell `wrangler deploy`
  // som aldrig speglades hit i git — dokumenterar dem nu så nästa deploy från
  // main inte tyst tar bort dem). Se worker/src/index.ts scheduled()-switchen.
  "triggers": {
    "crons": ["*/5 * * * *", "0 7 * * *", "0 7 * * 1"]
  },
  "upload_source_maps": true,
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  }
  // Secrets (wrangler secret put, körs manuellt av användaren):
  //   GITHUB_WEBHOOK_SECRET — delad hemlighet satt när org-webhooken skapas
  //   HEARTBEAT_SECRET      — delad hemlighet för /webhook/heartbeat (mp100, VPS:ar postar med denna)
  //   GITHUB_TOKEN          — fine-grained PAT, issues:write på alla repon, för auto-merge-armering och @claude-eskalering
  //   CF_ADMIN_TOKEN        — Cloudflare account-token, veckovis förnyelse av MANAGED_CF_TOKENS
  //   CF_READONLY_TOKEN     — Cloudflare account-token, läser Workers/D1/Access-status för hälsokontroller
  //   SLACK_BOT_TOKEN       — valfri, chat.postMessage för utgående alerts (annars SLACK_WEBHOOK_URL som fallback)
  //   SLACK_WEBHOOK_URL     — valfri, incoming webhook-fallback för utgående alerts
}
